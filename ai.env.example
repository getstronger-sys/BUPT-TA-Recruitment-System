TA_AI_ENABLED=true
TA_AI_PROVIDER=deepseek
TA_AI_BASE_URL=https://api.deepseek.com
TA_AI_MODEL=deepseek-chat
TA_AI_API_KEY=YOUR_API_KEY_HERE

# Generic OpenAI-compatible aliases are also supported:
# LLM_ENABLED=true
# LLM_BASE_URL=https://api.example.com/v1
# LLM_MODEL=provider-model-name
# LLM_API_KEY=YOUR_API_KEY_HERE

# MIMO example:
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# LLM_MODEL=mimo-v2.5-pro
# MIMO_API_KEY=YOUR_API_KEY_HERE
