<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>BUPT TA Recruitment System</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session timeout 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- TA Servlets -->
    <servlet>
        <servlet-name>TAProfileServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.TAProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TAProfileServlet</servlet-name>
        <url-pattern>/ta/profile</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CVUploadServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.CVUploadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CVUploadServlet</servlet-name>
        <url-pattern>/ta/upload-cv</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewCVServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.ViewCVServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewCVServlet</servlet-name>
        <url-pattern>/view-cv</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TADashboardServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.TADashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TADashboardServlet</servlet-name>
        <url-pattern>/ta/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>JobSearchServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.JobSearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JobSearchServlet</servlet-name>
        <url-pattern>/ta/jobs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TAJobDetailServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.TAJobDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TAJobDetailServlet</servlet-name>
        <url-pattern>/ta/job</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SavedJobsServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.SavedJobsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SavedJobsServlet</servlet-name>
        <url-pattern>/ta/saved-jobs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SaveJobServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.SaveJobServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SaveJobServlet</servlet-name>
        <url-pattern>/ta/save-job</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ApplyConfirmServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.ApplyConfirmServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplyConfirmServlet</servlet-name>
        <url-pattern>/ta/apply-confirm</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ApplyJobServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.ApplyJobServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplyJobServlet</servlet-name>
        <url-pattern>/ta/apply</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ApplicationStatusServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.ApplicationStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplicationStatusServlet</servlet-name>
        <url-pattern>/ta/applications</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>WithdrawApplicationServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.WithdrawApplicationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WithdrawApplicationServlet</servlet-name>
        <url-pattern>/ta/withdraw</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TAMessagesServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.TAMessagesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TAMessagesServlet</servlet-name>
        <url-pattern>/ta/messages</url-pattern>
    </servlet-mapping>

    <!-- MO Servlets -->
    <servlet>
        <servlet-name>PostJobServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.PostJobServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PostJobServlet</servlet-name>
        <url-pattern>/mo/post-job</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MOJobsServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.MOJobsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MOJobsServlet</servlet-name>
        <url-pattern>/mo/jobs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MOPastJobsServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.MOPastJobsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MOPastJobsServlet</servlet-name>
        <url-pattern>/mo/past-jobs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MOJobDetailServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.MOJobDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MOJobDetailServlet</servlet-name>
        <url-pattern>/mo/job</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MOUpdateWorkTaCountsServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.MOUpdateWorkTaCountsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MOUpdateWorkTaCountsServlet</servlet-name>
        <url-pattern>/mo/update-work-ta-counts</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ApplicantDetailServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.ApplicantDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplicantDetailServlet</servlet-name>
        <url-pattern>/mo/applicant-detail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SelectApplicantServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.SelectApplicantServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SelectApplicantServlet</servlet-name>
        <url-pattern>/mo/select-applicant</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MOBatchApplicantServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.MOBatchApplicantServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MOBatchApplicantServlet</servlet-name>
        <url-pattern>/mo/batch-applicants</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CloseJobServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.CloseJobServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CloseJobServlet</servlet-name>
        <url-pattern>/mo/close-job</url-pattern>
    </servlet-mapping>

    <!-- Admin Servlet -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminMonitoringServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.AdminMonitoringServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminMonitoringServlet</servlet-name>
        <url-pattern>/admin/monitoring</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminWorkloadServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.AdminWorkloadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminWorkloadServlet</servlet-name>
        <url-pattern>/admin/workload</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ExportWorkloadServlet</servlet-name>
        <servlet-class>bupt.ta.servlet.ExportWorkloadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExportWorkloadServlet</servlet-name>
        <url-pattern>/admin/export-workload</url-pattern>
    </servlet-mapping>

    <!-- Auth Filter -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>bupt.ta.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/ta/*</url-pattern>
        <url-pattern>/mo/*</url-pattern>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <error-page>
        <error-code>404</error-code>
        <location>/404.jsp</location>
    </error-page>
</web-app>
